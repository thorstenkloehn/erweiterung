{
  "name": "lernerweiterung",
  "displayName": "Lernerweiterung",
  "description": "Visual Studio Code Lernplattform für interaktives Programmieren.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onView:codekurs-explorer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codekurs-sidebar",
          "title": "Lernerweiterung"
        }
      ]
    },
    "views": {
      "codekurs-sidebar": [
        {
          "id": "codekurs-explorer",
          "name": "Kurs-Explorer"
        }
      ]
    },
    "commands": [
      {
        "command": "codekurs.checkCode",
        "title": "Aufgabe prüfen",
        "icon": "$(check)"
      },
      {
        "command": "codekurs.refreshCourses",
        "title": "Kurse aktualisieren",
        "icon": "$(refresh)"
      },
      {
        "command": "codekurs.createExercise",
        "title": "Eigene Übung erstellen",
        "icon": "$(add)"
      },
      {
        "command": "codekurs.openLesson",
        "title": "Lektion lesen"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codekurs.checkCode",
          "group": "navigation",
          "when": "resourceExtname == .py"
        }
      ],
      "view/title": [
        {
          "command": "codekurs.refreshCourses",
          "group": "navigation",
          "when": "view == codekurs-explorer"
        },
        {
          "command": "codekurs.createExercise",
          "group": "navigation",
          "when": "view == codekurs-explorer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/node": "16.x",
    "@types/marked": "^5.0.0",
    "@types/js-yaml": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "eslint": "^8.39.0",
    "typescript": "^5.0.4",
    "glob": "^8.1.0"
  },
  "dependencies": {
    "marked": "^5.0.0",
    "js-yaml": "^4.1.0"
  }
}