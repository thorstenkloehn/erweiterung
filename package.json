{
  "name": "lernerweiterung",
  "displayName": "Lernerweiterung",
  "description": "Visual Studio Code Lernplattform für interaktives Programmieren.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "onView:codekurs-explorer",
    "onView:codekurs-start"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codekurs-sidebar",
          "title": "Lernerweiterung"
        }
      ]
    },
    "views": {
      "codekurs-sidebar": [
        {
          "id": "codekurs-explorer",
          "name": "Kurs-Explorer"
        },
        {
          "id": "codekurs-start",
          "name": "Einstieg"
        }
      ]
    },
    "commands": [
      {
        "command": "codekurs.checkCode",
        "title": "Aufgabe prüfen",
        "icon": "$(check)"
      },
      {
        "command": "codekurs.refreshCourses",
        "title": "Kurse aktualisieren",
        "icon": "$(refresh)"
      },
      {
        "command": "codekurs.createExercise",
        "title": "Eigene Übung erstellen",
        "icon": "$(add)"
      },
      {
        "command": "codekurs.openLesson",
        "title": "Lektion lesen"
      },
      {
        "command": "codekurs.startPythonCourse",
        "title": "Python-Kurs starten"
      }
    ],
    "walkthroughs": [
      {
        "id": "lernerweiterung.welcome",
        "title": "Willkommen zur Lernerweiterung",
        "description": "Lerne Schritt für Schritt, wie du diese Erweiterung nutzt, um Programmieren zu lernen.",
        "steps": [
          {
            "id": "lernerweiterung.step.intro",
            "title": "Willkommen!",
            "description": "Diese Erweiterung hilft dir dabei, Programmiersprachen wie Python, Java, C und viele mehr direkt in VS Code zu erlernen.\n[Lernerweiterung Webseite](https://example.com)",
            "media": {
              "image": "media/welcome.svg",
              "altText": "Willkommen Bild"
            }
          },
          {
            "id": "lernerweiterung.step.explorer",
            "title": "Kurs-Explorer öffnen",
            "description": "Klicke auf das Buch-Icon in der Seitenleiste, um alle verfügbaren Kurse zu sehen.",
            "media": {
              "image": "media/explorer.svg",
              "altText": "Explorer Bild"
            },
            "button": {
              "command": "codekurs-explorer.focus",
              "label": "Explorer öffnen"
            }
          },
          {
            "id": "lernerweiterung.step.firstLesson",
            "title": "Deine erste Lektion",
            "description": "Starte mit der Python-Einführung und schreibe dein erstes Programm.",
            "media": {
              "image": "media/python.svg",
              "altText": "Python Bild"
            },
            "button": {
              "command": "codekurs.startPythonCourse",
              "label": "Kurs starten"
            }
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codekurs.checkCode",
          "group": "navigation",
          "when": "resourceExtname =~ /\\.(py|js|ts|rs|c|cpp|cs|java)$/"
        }
      ],
      "view/title": [
        {
          "command": "codekurs.refreshCourses",
          "group": "navigation",
          "when": "view == codekurs-explorer"
        },
        {
          "command": "codekurs.createExercise",
          "group": "navigation",
          "when": "view == codekurs-explorer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/node": "16.x",
    "@types/marked": "^5.0.0",
    "@types/js-yaml": "^4.0.5",
    "@typescript-eslint/eslint-plugin": "^5.59.1",
    "@typescript-eslint/parser": "^5.59.1",
    "eslint": "^8.39.0",
    "typescript": "^5.0.4",
    "glob": "^8.1.0"
  },
  "dependencies": {
    "marked": "^5.0.0",
    "js-yaml": "^4.1.0"
  }
}